# Required: Flask session signing key (use a long random value)
SECRET_KEY="replace-with-a-long-random-secret"

# Required on first startup if no users exist yet
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD="replace-with-a-strong-admin-password"

# Public base URL used by the app for QR/public links
BASE_URL=https://your-domain.example
DOMAIN=your-domain.example
# DOMAIN is used by deployment/nginx/certbot tooling (not by app runtime routes directly)

# Optional: login brute-force protection
LOGIN_WINDOW_SECONDS=900
LOGIN_MAX_ATTEMPTS=5

# Optional: password policy
MIN_PASSWORD_LENGTH=10

# Optional: TOTP label shown in authenticator apps
TOTP_ISSUER="Lost & Found"

# Optional: trusted reverse-proxy CIDR ranges for client IP extraction
TRUSTED_PROXY_CIDRS=127.0.0.1/32,::1/128,172.16.0.0/12

# Optional: cookie and upload hardening
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=Lax
# Optional: absolute max login session age in seconds (browser session cookie still used)
SESSION_MAX_AGE_SECONDS=28800

MAX_CONTENT_LENGTH=20971520

# Optional: public lost form abuse protection
PUBLIC_LOST_WINDOW_SECONDS=900
PUBLIC_LOST_MAX_ATTEMPTS=8
PUBLIC_LOST_DAILY_MAX_ATTEMPTS=30
PUBLIC_LOST_MAX_FILES=5
PUBLIC_LOST_CAPTCHA_ENABLED=false

# Optional: auto-delete items after N months without updates (0 disables automatic deletion)
ITEM_RETENTION_MONTHS=12

# Optional: storage paths (mainly for non-Docker runs; Docker Compose sets these internally)
DATA_DIR=/app/data
UPLOAD_DIR=/app/uploads

# Optional: local debug mode (do not enable in production)
FLASK_DEBUG=false

# Optional: audit log rotation (daily maintenance)
# Keep entries for N days (0 disables age-based cleanup)
AUDIT_RETENTION_DAYS=180
# Hard cap of audit rows (0 disables count-based cleanup)
AUDIT_MAX_ROWS=200000
# Optional: mask sensitive values in audit snapshots
AUDIT_REDACT_ENABLED=true

# Optional: encryption key for secrets stored in DB (required for encrypted SMTP password storage)
SETTINGS_ENCRYPTION_KEY="replace-with-a-long-random-secret"

# Optional: Roundcube webmail bridge
ROUNDCUBE_ENABLED=false
ROUNDCUBE_SHARED_SECRET="replace-with-a-second-long-random-secret"
ROUNDCUBE_DES_KEY="replace-with-a-third-long-random-secret"
ROUNDCUBE_EXTERNAL_URL=/webmail/
ROUNDCUBE_REQUEST_PATH=/webmail/
ROUNDCUBE_SSO_MAX_AGE_SECONDS=900
